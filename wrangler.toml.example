name = "austinxyz-lol"
compatibility_date = "2024-01-01"
pages_build_output_dir = "out"

# KV namespace binding shared by telemetry endpoints AND the TWM share-stats
# endpoints.  TWM reuses this namespace under per-slot keys of the form
# `twm:slot:<slot_id>`.
#
# Get your KV namespace ID from the Cloudflare Dashboard:
#   Workers & Pages > KV > Your namespace
[[kv_namespaces]]
binding = "TELEMETRY_KV"
id = "YOUR_KV_NAMESPACE_ID_HERE"

# The TWM share-stats flow is fully self-provisioning — there are NO
# environment variables to configure.  The bot generates an unguessable
# `slot_id` + `push_secret` on its first "Share Stats" click and the very
# first push to /api/twm/push/<slot_id> claims the slot via TOFU (trust on
# first use).  No `TWM_PUSH_SECRET`, no `TWM_VIEWER_TOKEN`, no manual KV
# setup beyond the binding above.
