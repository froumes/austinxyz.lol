name = "austinxyz-lol"
compatibility_date = "2024-01-01"
pages_build_output_dir = "out"

# KV namespace binding shared by telemetry endpoints AND the TWM share-stats
# endpoints.  TWM reuses this namespace under per-slot / per-vanity /
# per-Discord-user keys of the form:
#
#   twm:slot:<slot_id>        - pushed stats payload keyed by slot
#   twm:vanity:<username>     - Discord username → slot id (pretty URL)
#   twm:discord:<user_id>     - Discord user → current vanity + slot
#   twm:oauth_state:<nonce>   - 5-minute-TTL OAuth flow state
#
# Get your KV namespace ID from the Cloudflare Dashboard:
#   Workers & Pages > KV > Your namespace
[[kv_namespaces]]
binding = "TELEMETRY_KV"
id = "YOUR_KV_NAMESPACE_ID_HERE"

[[kv_namespaces]]
binding = "TWM_AUTH_KV"
id = "YOUR_KV_NAMESPACE_ID_HERE"

# ─── TWM stats push/view ─────────────────────────────────────────────
# Fully self-provisioning — there are NO env vars to configure.  The bot
# generates an unguessable slot_id + push_secret on its first "Share
# Stats" click, and the very first push to /api/twm/push/<slot_id>
# claims the slot via TOFU (trust on first use).

# ─── Discord OAuth vanity-URL linking + TWM central licensing ────────
# Optional.  Enables Discord OAuth features for stats vanity URLs and
# the central TWM licensing flow at /api/twm/*.
#
# Important: when wrangler.toml is committed, Cloudflare Pages locks the
# dashboard to read-only for plaintext variables — they MUST be defined
# below.  Only Secrets remain dashboard-managed.  See:
#   https://developers.cloudflare.com/pages/functions/wrangler-configuration/
#
# What goes where:
#   DISCORD_CLIENT_ID      — plaintext, in [vars] below.  Public.
#   DISCORD_REDIRECT_URI   — plaintext, in [vars] below.  Must match the
#                            vanity URL callback in Discord.
#   TWM_AUTH_BASE_URL      — plaintext, in [vars] below.  Must match the
#                            central auth domain, e.g. https://auth.example.com.
#   DISCORD_CLIENT_SECRET  — SECRET.  Set in Pages dashboard.  NEVER commit.
#   TWM_ADMIN_API_KEY      — SECRET.  Set in Pages dashboard.  NEVER commit.
#
# Required OAuth scope: `identify`.

[vars]
DISCORD_CLIENT_ID = "REPLACE_WITH_YOUR_DISCORD_CLIENT_ID"
DISCORD_REDIRECT_URI = "https://austinxyz.lol/auth/discord/callback"
TWM_AUTH_BASE_URL = "https://auth.austinxyz.lol"
